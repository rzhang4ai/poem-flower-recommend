# 复制本文件为 .env，填入你的配置
# cp 05.recommend/.env.example 05.recommend/.env
#
# ── Google Gemini API（推荐，主力）────────────────────────────────────────
# 在 https://aistudio.google.com/apikey 免费获取
GOOGLE_API_KEY=your_google_api_key_here

# 聊天模型（意图解析）— thinking 模型已在代码里强制 thinking_budget=0
GEMINI_CHAT_MODEL=gemini-3-flash-preview

# 嵌入模型（语义匹配）— 多模态嵌入预览版；纯文本检索仍可用
GEMINI_EMBED_MODEL=gemini-embedding-2-preview

# ── Doubao / Ark API（备用 fallback）────────────────────────────────────
# 若 GOOGLE_API_KEY 已填写，以下配置可不填
# 在 https://console.volcengine.com/ark 获取
# ARK_API_KEY=your_ark_api_key_here
# ARK_CHAT_MODEL=doubao-pro-32k
# ARK_EMBED_MODEL=doubao-embedding-large-text
# ARK_BASE_URL=https://ark.volces.com/api/v3/
