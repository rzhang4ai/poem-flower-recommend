# 复制本文件为 secrets.toml，填入真实 key（本地开发用）
# Streamlit Cloud 上直接在后台 Settings → Secrets 粘贴这些 key

# ── Google Gemini（必填）──────────────────────────────────────────
GOOGLE_API_KEY      = "AIza..."
GEMINI_CHAT_MODEL   = "gemini-2.0-flash"     # 或 gemini-3-flash-preview
GEMINI_EMBED_MODEL  = "gemini-embedding-2-preview"

# ── 豆包 Doubao（可选备用）───────────────────────────────────────
# ARK_API_KEY      = "..."
# ARK_CHAT_MODEL   = "doubao-pro-32k"
# ARK_EMBED_MODEL  = "doubao-embedding-large-text"
